---
import Sign from "@components/Sign.svelte";
interface Props {
    hideSmall: boolean;
}

const { hideSmall } = Astro.props;
const clss = hideSmall ? "hidden lg:block" : "block lg:hidden";
---

<div class=`overflow-y-clip flex-1 min-h-0 max-w-full lg:max-w-lg ${clss}`>
    <div class="aspect-square h-full max-w-full max-h-full mb-[-20%] translate-y-[20%]">
        <Sign client:load />
    </div>
</div>
